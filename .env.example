# Database Configuration
DATABASE_URL=postgresql://user:password@host:port/database

# Application Configuration
APP_SECRET=your-secret-key-here
APP_BASE_URL=http://your-onion-address.onion
APP_DEBUG=false

# CryptAPI Configuration - Payout Addresses
PAYOUT_BTC=your-btc-address
PAYOUT_XMR=your-xmr-address
PAYOUT_ETH=your-eth-address
PAYOUT_SOL=your-sol-address
PAYOUT_DOGE=your-doge-address

# Payment Confirmation Requirements
PAY_CONF_DEFAULT=1
PAY_CONF_BTC=1
PAY_CONF_XMR=10
PAY_CONF_ETH=12
PAY_CONF_SOL=1
PAY_CONF_DOGE=6

# Tatum API Configuration
TATUM_API_URL=https://api.tatum.io/v3
TATUM_API_KEY=your-tatum-api-key

# Upload Configuration
UPLOAD_MAX_SIZE=15242880
UPLOAD_MAX_FILES=20
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp

# Pricing (in USD cents)
LISTING_PRICE_CENTS=100
BUMP_PRICE_CENTS=50

# Session Configuration
SESSION_LIFETIME=86400
CSRF_TOKEN_LIFETIME=3600

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600